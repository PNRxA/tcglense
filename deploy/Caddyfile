# TCGLense production reverse proxy (Caddy v2).
#
# Serves the built Vue SPA AND forwards /api/* to the Rust API on the same origin,
# so the httpOnly refresh cookie stays first-party. Caddy auto-provisions HTTPS for
# a real domain (needs ports 80+443 reachable and DNS pointing at this host).
#
#   caddy run --config deploy/Caddyfile
#
# Edit the domain and the site root below to match your server. To test locally,
# change the site address to `localhost` (Caddy issues a local-CA cert).

tcglense.example.com {
	encode zstd gzip

	# API: forward /api/* to the Rust backend (bound to 127.0.0.1 in production).
	# `handle` (not `handle_path`) preserves the /api prefix the backend expects.
	# The root sitemap paths are API-served too (issue #294): the sitemap index
	# must live at the site root for the sitemap-protocol scope rule to cover the
	# whole site.
	handle /api/* {
		reverse_proxy 127.0.0.1:8080
	}
	handle /sitemap.xml {
		reverse_proxy 127.0.0.1:8080
	}
	handle /sitemaps/* {
		reverse_proxy 127.0.0.1:8080
	}
	# robots.txt is API-served too, so its Sitemap: line is an absolute PUBLIC_SITE_URL
	# (the web build no longer emits a static one).
	handle /robots.txt {
		reverse_proxy 127.0.0.1:8080
	}

	# Social/link unfurlers + search bots asking for an HTML page get server-rendered
	# per-page meta from the API (issue #302 dynamic rendering) instead of index.html's
	# static homepage tags. The `not path` excludes asset extensions so a crawler's
	# /assets/*.js etc. still hit the static SPA below. Keep this UA regex in sync with
	# CRAWLER_UA_NEEDLES in api/src/handlers/prerender/mod.rs.
	@crawlerHtml {
		header_regexp User-Agent (?i)(facebookexternalhit|facebot|twitterbot|slackbot|slack-imgproxy|discordbot|linkedinbot|whatsapp|telegrambot|redditbot|pinterest|applebot|skypeuripreview|embedly|quora link preview|nuzzel|flipboard|tumblr|mastodon|bluesky|cardyb|iframely|google-inspectiontool|googlebot|bingbot|duckduckbot|yandexbot|baiduspider)
		not path *.js *.mjs *.css *.map *.png *.jpg *.jpeg *.gif *.svg *.webp *.avif *.ico *.json *.xml *.txt *.woff *.woff2 *.ttf
	}
	handle @crawlerHtml {
		rewrite * /api/prerender{uri}
		reverse_proxy 127.0.0.1:8080
	}

	# SPA: serve the static build, falling back to index.html so client-side
	# routes (/login, /register, ...) resolve. `Vary: User-Agent` so a shared CDN
	# keeps the browser shell and the crawler prerender (above) separate.
	handle {
		root * /srv/tcglense/web
		header Vary User-Agent
		try_files {path} /index.html
		file_server
	}
}

# Environment for the DigitalOcean + Upstash + Cloudflare deploy.
# Copy to `.env` next to docker-compose.do.yml and fill in. Full guide:
# docs/deploy-digitalocean.md. Keep this file OUT of version control once filled.

# Your domain (must be proxied through Cloudflare).
SITE_ADDRESS=tcglense.example.com

# Pin a release (defaults to :latest if unset).
# IMAGE_TAG=v0.1.0

# Required. Generate once: openssl rand -hex 32
JWT_SECRET=

# DigitalOcean Managed Postgres — the PRIVATE (VPC) connection string. Port 25060,
# and ?sslmode=require is mandatory (DO requires TLS; the API supports it).
DATABASE_URL=postgres://doadmin:PASSWORD@private-db-host:25060/tcglense?sslmode=require

# Upstash Redis — the rediss:// (TLS) URL from the Upstash console. Optional: leave
# empty to run the rate limiter in-memory (single-instance). Required for >1 replica.
REDIS_URL=rediss://default:PASSWORD@your-db.upstash.io:6379

# Cloudflare Turnstile — BOTH are required by this production stack. The site key
# is public and applied at runtime, so no image rebuild is needed to change it.
TURNSTILE_SECRET_KEY=
TURNSTILE_SITE_KEY=

# Email (Resend) — REQUIRED in production (see the guide). EMAIL_FROM must be a
# verified-domain sender.
RESEND_API_KEY=
EMAIL_FROM=TCGLense <no-reply@tcglense.example.com>

# Launch switch. Leave false through the first deployment and verification, then
# set true and recreate the api container when you are ready to accept accounts.
SIGNUPS_ENABLED=false
SIGNUPS_DISABLED_MESSAGE=New registrations are not open yet.

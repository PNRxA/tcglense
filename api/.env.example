# TCGLense API configuration
# Copy this file to `.env` and adjust the values for your environment.

# SQLite connection string. `mode=rwc` creates the file if it does not exist.
DATABASE_URL=sqlite://tcglense.db?mode=rwc

# Secret used to sign JWTs (HS256). REQUIRED in production.
# If unset, the server falls back to an insecure dev-only secret and logs a warning.
JWT_SECRET=change-me-to-a-long-random-secret

# Lifetime of a short-lived access JWT, in minutes. Defaults to 15.
# The client keeps the access token in memory only and sends it as a
# `Authorization: Bearer <token>` header on protected routes.
ACCESS_TOKEN_EXPIRY_MINUTES=15

# Lifetime of a long-lived opaque refresh token, in days. Defaults to 30.
# Refresh tokens are delivered only as the httpOnly `tcglense_refresh` cookie
# and stored server-side as a SHA-256 hash.
REFRESH_TOKEN_EXPIRY_DAYS=30

# Whether the refresh cookie is marked `Secure` (sent over HTTPS only).
# Keep false for local http://localhost development; set true in production.
COOKIE_SECURE=false

# Network interface to bind. 0.0.0.0 for local dev / containers; set 127.0.0.1 in
# production so only a front proxy (e.g. Caddy) can reach the API. Defaults to 0.0.0.0.
HOST=0.0.0.0

# Port the HTTP server binds to. Defaults to 8080.
PORT=8080

# Logging filter for tracing-subscriber (env-filter syntax). Defaults to "info".
RUST_LOG=info

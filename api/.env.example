# TCGLense API configuration
# Copy this file to `.env` and adjust the values for your environment.
#
# QUOTING: any value containing spaces MUST be wrapped in double quotes — e.g. the
# *_USER_AGENT and EMAIL_FROM values below. An unquoted space is a parse error that makes
# the loader stop and silently skip every variable defined after it (they fall back to
# their defaults), which is a nasty, hard-to-spot failure. When in doubt, quote it.

# Database connection string. The scheme selects the backend at runtime:
#   - SQLite (default): `mode=rwc` creates the file if it does not exist.
#   - Postgres (optional): postgres://USER:PASSWORD@HOST:5432/DBNAME
# SQLite is the default and needs nothing installed; Postgres is for multi-instance /
# managed-database deploys. Migrations run on boot against whichever backend (both
# drivers are compiled in — no cargo feature). SQLite behaviour is unchanged.
DATABASE_URL=sqlite://tcglense.db?mode=rwc
# DATABASE_URL=postgres://tcglense:tcglense@localhost:5432/tcglense

# Postgres connection-pool sizing (ignored on SQLite, which sea-orm pins to one
# connection). Defaults: max 10, min 1, connect timeout 15s, acquire timeout 30s.
# min 1 keeps one connection warm so the first request after idle skips connect latency.
# Size DB_MAX_CONNECTIONS to the server's max_connections divided by the instance count.
# DB_MAX_CONNECTIONS=10
# DB_MIN_CONNECTIONS=1
# DB_CONNECT_TIMEOUT_SECS=15
# DB_ACQUIRE_TIMEOUT_SECS=30

# Secret used to sign JWTs (HS256). REQUIRED: the server refuses to start if this
# is unset (unless ALLOW_INSECURE_DEV_SECRET=true, below). Must be >= 32 bytes of
# high-entropy randomness and must not be the public dev fallback value.
# Generate one with: openssl rand -hex 32
JWT_SECRET=change-me-run-openssl-rand-hex-32-to-generate-a-real-secret

# Local-dev escape hatch: set true to allow booting WITHOUT a JWT_SECRET using a
# publicly-known, insecure compiled-in secret. NEVER set this outside local dev.
# ALLOW_INSECURE_DEV_SECRET=false

# Lifetime of a short-lived access JWT, in minutes. Defaults to 15.
# The client keeps the access token in memory only and sends it as a
# `Authorization: Bearer <token>` header on protected routes.
ACCESS_TOKEN_EXPIRY_MINUTES=15

# Lifetime of a long-lived opaque refresh token, in days. Defaults to 30.
# Refresh tokens are delivered only as the httpOnly `tcglense_refresh` cookie
# and stored server-side as a SHA-256 hash.
REFRESH_TOKEN_EXPIRY_DAYS=30

# Whether the refresh cookie is marked `Secure` (sent over HTTPS only).
# Keep false for local http://localhost development; set true in production.
COOKIE_SECURE=false

# Network interface to bind. Defaults to 127.0.0.1 (loopback only). Set 0.0.0.0 to
# expose the API on all interfaces (containers, or reaching the dev API from a LAN).
HOST=127.0.0.1

# Port the HTTP server binds to. Defaults to 8080.
PORT=8080

# Optional directory of built SPA static files for the API to serve itself. When
# set, any request not matched by an /api route is served from this directory, with
# unknown paths falling back to index.html so client-side SPA routes resolve. Unset
# (the default) = the API serves only /api. This is how the single-process
# "combined" Docker image serves the API and the SPA from one binary (it sets
# WEB_ROOT=/srv/web); the split deployment (Caddy serving the SPA, proxying /api)
# leaves it unset.
# WEB_ROOT=/srv/web

# Server-side "dynamic rendering for bots" (handlers::prerender) serves per-route
# social/link-preview meta to recognised crawler User-Agents so shared links stop
# unfurling as the homepage. Set this to true to DROP the crawler-UA gate and
# prerender EVERY client on an HTML navigation. Default false. Caveat: with WEB_ROOT
# set, real browsers then receive the minimal prerender document instead of the
# interactive SPA — enable only for a setup that wants server-rendered pages for all.
# PRERENDER_ALL_USER_AGENTS=false

# Public origin where the SPA is served, used to build the absolute <loc> URLs in
# the DB-backed sitemaps (GET /api/sitemap.xml — see issue #75). Set this to the
# real site origin in production (e.g. https://tcglense.app). Trailing slashes are
# trimmed. Defaults to the Vite dev origin so dev/e2e produce valid URLs.
PUBLIC_SITE_URL=http://localhost:5173

# Logging filter for tracing-subscriber (env-filter syntax). Defaults to "info".
RUST_LOG=info

# ----- Transactional email (Resend) -----

# API key for Resend (https://resend.com), used to send the registration-
# completion, account-verification, and password-reset emails. Treat it as a
# secret. Leave unset to DISABLE email (the dev/CI posture): register then
# returns the registration-completion token directly in its response instead of
# emailing the link (complete-registration sets the password and signs in), and
# login skips the "email not verified" gate. Set a real key in production, or
# unowned addresses could be registered and signed in without any mailbox proof.
# RESEND_API_KEY=

# `From` address on outbound email. The domain must be verified with Resend.
# Defaults to Resend's shared onboarding sender, which only delivers to the
# Resend account owner's own address — fine for dev, set a real one in production.
# EMAIL_FROM="TCGLense <no-reply@your-domain.example>"

# ----- New-user signups -----

# Whether new-account registration is accepted. Default true (open). Set false to
# temporarily stop new signups while EXISTING users keep signing in normally:
# /api/auth/register and /complete-registration are refused with a 403, and the
# SPA shows the notice below and disables its signup form. Gates only registration.
# SIGNUPS_ENABLED=true

# Optional message shown to visitors when SIGNUPS_ENABLED=false. Unset = a generic
# "registration is temporarily disabled" notice. Not a secret (it's shown to
# users) — served to the SPA via GET /api/config alongside the flag.
# SIGNUPS_DISABLED_MESSAGE="Signups are paused while we scale up — check back soon!"

# ----- Anti-abuse (CAPTCHA + rate limiting) -----

# Cloudflare Turnstile keys for the auth-form CAPTCHA. Set BOTH or NEITHER — a
# mismatched pair fails the boot closed (set only the secret and every auth submit
# 400s; set only the site key and the token is never verified).
#   TURNSTILE_SECRET_KEY — verifies the token server-side. Treat it as a secret.
#   TURNSTILE_SITE_KEY   — the PUBLIC site key the browser widget renders with. Not
#                          a secret; served to the SPA at runtime via GET /api/config
#                          (so the published web image needs no rebuild to change it).
# Leave both unset to DISABLE CAPTCHA (checks pass; no widget) — the dev/test default.
# TURNSTILE_SECRET_KEY=
# TURNSTILE_SITE_KEY=

# Whether to trust X-Forwarded-For / Forwarded when resolving the client IP for
# rate limiting. Default false (use the socket peer). Set true ONLY when the API
# runs behind a trusted reverse proxy AND that proxy REPLACES/strips any inbound
# X-Forwarded-For (the left-most entry is used as the client; an appending proxy,
# or a directly-exposed server, lets clients spoof it and evade the per-IP limits).
# TRUST_PROXY_HEADERS=false

# Master switch for the per-IP auth rate limiting (login/register/email/token
# endpoints). Default true; set false to defer entirely to an upstream WAF/proxy.
# RATE_LIMIT_ENABLED=true

# Optional Redis URL backing the per-IP + per-user rate limiters. When set, the
# limiter state lives in Redis so it is SHARED across instances (a multi-instance
# deploy enforces one global quota). Unset = in-memory per-process limiters (the
# default; fine for a single instance). On a Redis outage the limiter fails OPEN,
# degrading to in-memory for that check. Only plain `redis://` is supported (this
# build links the no-TLS redis feature set; a `rediss://` URL degrades to in-memory).
# Requires Redis 5.0+ (the limiter Lua script uses server TIME + SET, rejected by
# older Redis's script effect replication). Treat a URL that embeds a password as a secret.
# REDIS_URL=redis://localhost:6379

# ----- Card catalog (Scryfall) -----

# Base directory for downloaded assets. Card images are lazily downloaded on first
# view and cached under `<DATA_DIR>/images/`. Defaults to ./data (gitignored).
DATA_DIR=./data

# CDN mode for the image/icon proxy. When true, card images and set icons are NOT
# cached on local disk: the origin still fetches each asset from Scryfall on demand
# and serves it with the same long `immutable` cache headers, but skips writing it
# under `<DATA_DIR>/images/`. Intended for deployments fronted by a CDN that caches
# those responses, so the origin needs no writable image directory and is only hit
# on a CDN cache miss. Leave false if no CDN sits in front (otherwise every view
# re-fetches from Scryfall). Defaults to false.
CDN_MODE=false

# User-Agent sent to Scryfall. Their API guidelines require a descriptive one;
# include a contact URL/email so they can reach you if needed. Quote it — the value
# contains spaces (see the QUOTING note at the top of this file).
SCRYFALL_USER_AGENT="TCGLense/0.1 (+https://github.com/PNRxA/tcglense)"

# ----- Historic price backfill (TCGCSV) -----

# User-Agent sent to TCGCSV (https://tcgcsv.com) for the one-time historic price
# backfill. TCGCSV blocks generic/empty User-Agents, so use a descriptive one with
# a contact URL/email (same shape as SCRYFALL_USER_AGENT). Defaults to the same
# fallback as Scryfall's UA.
TCGCSV_USER_AGENT="TCGLense/0.1 (+https://github.com/PNRxA/tcglense)"

# Master switch for the one-time TCGCSV historic price backfill. When enabled, on the
# first boot after the Scryfall sync has populated the cards' TCGplayer ids the server
# downloads TCGCSV's daily price archives (one per day since 2024-02-08) and fills
# card_price_history for the days before it began capturing its own daily snapshots. It
# runs ONCE (gated by an ingest_state row) and never overwrites an existing (card, date)
# row. Off by default (opt-in) — the walk is slow and hits an external service; set true
# to run it.
PRICE_BACKFILL_ENABLED=false

# Cap the backfill to the most recent N archive days (useful to bound a first run).
# 0 (the default) = every archive day since 2024-02-08; N = only the last N days.
PRICE_BACKFILL_DAYS=0

# User-Agent sent to Moxfield for collection URL imports. Moxfield's API sits
# behind bot protection that rejects unknown clients; email support@moxfield.com
# to get a descriptive User-Agent string approved, then set it here. Leave unset
# if you haven't been approved — Moxfield URL imports will fail with a clear
# error, but Moxfield CSV uploads (no network fetch) always work. Quote it — a descriptive
# User-Agent contains spaces (see the QUOTING note at the top of this file).
# MOXFIELD_USER_AGENT="TCGLense/0.1 (+https://github.com/PNRxA/tcglense)"

# Import card data from providers (Scryfall) on startup. Runs in the background so
# the server is available immediately; progress is exposed at
# GET /api/games/mtg/status. Set false to disable ALL card-data syncing — both the
# startup import and the periodic refresh below (e.g. offline dev). Defaults true.
# (To populate a fake catalog offline instead of an empty one, see SEED_DUMMY_DATA.)
SYNC_ON_STARTUP=true

# How often to re-import card data after the startup import, in hours. Defaults to
# 24 (daily) so newer Scryfall prices/sets are picked up without a restart. The
# import is version-gated, so a tick with no upstream change is cheap. Set to 0 to
# disable the periodic refresh (import on startup only). Only applies when
# SYNC_ON_STARTUP is enabled.
SYNC_INTERVAL_HOURS=24

# Seed a small DUMMY offline catalog instead of importing real card data from
# Scryfall. When true this TAKES PRECEDENCE over SYNC_ON_STARTUP / SYNC_INTERVAL_HOURS:
# the server inserts a handful of deterministic fake sets/cards on startup and does
# NO network sync (no bulk download, no periodic refresh). The cards have no images
# (the UI shows placeholders), so the catalog works fully offline — handy for local
# dev, CI, and tests. It upserts and never deletes, so point it at a fresh/dedicated
# DB, not one that already holds real imported data. Defaults to false.
SEED_DUMMY_DATA=false

# ----- Dataset source / mirror -----
#
# Where the background sync pulls the big raw dataset files from — Scryfall's
# default_cards bulk file + set list, MTGJSON's AllPrintings, and TCGCSV's
# catalog/prices/archives. By DEFAULT a self-host reads them from a TCGLense MIRROR
# (another instance re-serving them at /api/mirror/*, riding its CDN), so you offload
# the upstream services and don't need the bot-walled providers' User-Agents.

# Fetch the datasets DIRECTLY from Scryfall / MTGJSON / TCGCSV instead of the mirror.
# The mirror host itself sets this true (it's the one origin that talks to the real
# services). Defaults to false (read from the mirror at DATASET_MIRROR_URL).
SYNC_FROM_UPSTREAM=false

# Base origin of the TCGLense mirror to read datasets from when SYNC_FROM_UPSTREAM is
# false. Defaults to the public site. Point it at your own mirror if you run one.
DATASET_MIRROR_URL=https://tcglense.com

# Serve the dataset mirror endpoints (/api/mirror/*) from THIS instance so other
# TCGLense installs can pull the datasets from you. Responses carry CDN-cacheable
# headers so a fronting CDN absorbs the repeat downloads. Off by default so an
# ordinary self-host isn't an open proxy to the upstreams; the public mirror turns it
# on alongside SYNC_FROM_UPSTREAM=true. Defaults to false.
MIRROR_ENABLED=false

# ----- Visual card scanner (perceptual-hash fingerprints) -----
#
# The scanner matches a photographed card against an index of card-image perceptual
# hashes. A normal self-host IMPORTS a prebuilt index (distributed via the dataset
# mirror) and fetches ZERO images. Only the operator's index-building instance sets
# the flag below to build it.

# Build the fingerprint index on THIS instance: a small-size, hash-and-discard walk of
# the whole catalogue (nothing is persisted to the image cache). The image CDN isn't
# rate-limited, so there's no artificial per-request delay — the shared 8-way fetch
# concurrency cap is the only politeness bound. This is the one sanctioned bulk image
# fetch — leave it OFF on an ordinary self-host, which imports the derived index
# instead. Defaults to false.
FINGERPRINT_BUILD_ENABLED=false

# Import the prebuilt fingerprint index from the dataset mirror (DATASET_MIRROR_URL) so
# this instance's scanner works without ever fetching card images. On by default — the
# hassle-free posture for an ordinary self-host. Ignored when FINGERPRINT_BUILD_ENABLED
# is true (the builder produces the index itself). Set false to opt out of the scanner /
# any outbound index pull. The mirror it pulls from must have MIRROR_ENABLED=true.
FINGERPRINT_IMPORT_ENABLED=true

# Version stamped on built fingerprints + used to load the match index. Bump to
# invalidate every stored fingerprint and force a rebuild when the hash algorithm
# changes (also cache-busts the client). Defaults to 1.
FINGERPRINT_ALGO_VERSION=1

# How many ranked matches a scan returns (clamped to 1..25) — the candidate list the
# manual scanner lets you pick from. Defaults to 8.
FINGERPRINT_TOP_K=8

# Largest Hamming distance (of 256 bits) still returned as a candidate to pick from; a
# scan with nothing within this radius resolves to no match rather than a distant false
# positive. Generous so a weak (off-angle) but plausible scan still offers the right
# card. Defaults to 96.
FINGERPRINT_MAX_DISTANCE=96

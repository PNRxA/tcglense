# TCGLense API configuration
# Copy this file to `.env` and adjust the values for your environment.

# SQLite connection string. `mode=rwc` creates the file if it does not exist.
DATABASE_URL=sqlite://tcglense.db?mode=rwc

# Secret used to sign JWTs (HS256). REQUIRED in production.
# If unset, the server falls back to an insecure dev-only secret and logs a warning.
JWT_SECRET=change-me-to-a-long-random-secret

# Number of days a freshly issued JWT remains valid. Defaults to 7.
JWT_EXPIRY_DAYS=7

# Port the HTTP server binds to. Defaults to 8080.
PORT=8080

# Logging filter for tracing-subscriber (env-filter syntax). Defaults to "info".
RUST_LOG=info
